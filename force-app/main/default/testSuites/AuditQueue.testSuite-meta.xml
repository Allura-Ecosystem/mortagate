<?xml version="1.0" encoding="UTF-8"?>
<ApexTestSuite xmlns="http://soap.sforce.com/2006/04/metadata">
    <!--
      V4.2 — Audit-queue test-suite manifest.

      The audit-queue's own Apex coverage as a single named suite, so it runs
      with one command instead of hand-typed class names that drift:

        sf apex run test -o mortagate-de  suite-names AuditQueue  result-format human

      This is the suite the V2.4 decoupling option gates on (RunSpecifiedTests
      over the audit classes, independent of the org-wide RunLocalTests gate),
      and the same suite the V4.3 CI job should invoke. When a new audit test
      class is added, register it here so the run list stays in source,
      reviewed, and identical across local / CI / deploy contexts.
    -->
    <testClassName>AuditCaseServiceTest</testClassName>
    <testClassName>AuditDataIntegrityTest</testClassName>
    <testClassName>AuditEvidenceReportControllerTest</testClassName>
    <testClassName>AuditQueueControllerTest</testClassName>
</ApexTestSuite>
