<apex:page controller="AdverseActionNoticeController"
           renderAs="pdf"
           showHeader="false"
           sidebar="false"
           standardStylesheets="false"
           applyHtmlTag="true"
           applyBodyTag="true"
           title="Notice of Action Taken">
<!--
  ECOA / Regulation B (12 CFR 1002.9) adverse action notice, rendered as a PDF letter.
  Pure read: no apex:form, no inputs, no DML. All data flows through standard {!}
  escaping (no escape="false") because this letter is delivered to the applicant.
  Veridact brand applied. The regulated content blocks are labeled inline.
-->
<head>
    <style type="text/css">
        @page { margin: 1.6cm; }
        body {
            font-family: Arial, Helvetica, sans-serif;
            color: #1b2b5e;
            font-size: 11px;
            line-height: 1.55;
        }
        .accent-bar { background-color: #d4920a; height: 5px; width: 100%; }
        h1 {
            font-family: "Times New Roman", Georgia, serif;
            font-size: 20px;
            margin: 16px 0 2px 0;
            color: #1b2b5e;
        }
        .tagline { font-style: italic; color: #6b7280; margin: 0 0 16px 0; }
        .creditor { margin: 0 0 14px 0; }
        .creditor .name { font-weight: bold; }
        .meta { color: #6b7280; margin: 0 0 16px 0; }
        .salutation { margin: 0 0 10px 0; }
        p { margin: 0 0 10px 0; }
        .section-title {
            font-size: 12px;
            font-weight: bold;
            margin: 18px 0 6px 0;
            border-bottom: 2px solid #1b2b5e;
            padding-bottom: 3px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }
        ul.reasons { margin: 0 0 10px 18px; padding: 0; }
        ul.reasons li { margin: 0 0 6px 0; }
        .ecoa {
            background-color: #f5f3ec;
            border-left: 3px solid #d4920a;
            padding: 10px 12px;
            margin: 10px 0;
        }
        .score {
            background-color: #f3f4f6;
            padding: 10px 12px;
            margin: 10px 0;
        }
        .footer {
            margin-top: 24px;
            border-top: 1px solid #e5e7eb;
            padding-top: 8px;
            color: #6b7280;
            font-size: 9px;
        }
        .denied { color: #7c2d2d; font-weight: bold; margin-top: 24px; }
    </style>
</head>
<body>
    <div class="accent-bar"></div>

    <apex:outputPanel rendered="{!accessDenied}">
        <h1>Notice of Action Taken</h1>
        <p class="tagline">Every decision has a receipt.</p>
        <p class="denied">{!accessMessage}</p>
    </apex:outputPanel>

    <apex:outputPanel rendered="{!NOT(accessDenied)}">
        <h1>Notice of Action Taken</h1>
        <p class="tagline">Every decision has a receipt.</p>

        <apex:outputPanel rendered="{!notice != null}">
            <!-- Creditor identity (1002.9(a)(2)(i)) -->
            <div class="creditor">
                <div class="name">{!notice.creditorName}</div>
                <div>{!notice.creditorAddress}</div>
            </div>

            <div class="meta">
                <div>Date:
                    <apex:outputText value="{0,date,MMMM d, yyyy}">
                        <apex:param value="{!notice.noticeDate}" />
                    </apex:outputText>
                </div>
            </div>

            <p class="salutation">Dear {!notice.applicantName},</p>

            <!-- Statement of action taken (1002.9(a)(2)(i)) -->
            <p>{!notice.actionStatement}</p>

            <!-- Specific principal reasons (1002.9(b)(2)) -->
            <apex:outputPanel rendered="{!notice.isAdverseAction}" layout="none">
                <div class="section-title">Principal reasons for our decision</div>
                <apex:outputPanel rendered="{!notice.reasons.size > 0}" layout="none">
                    <ul class="reasons">
                        <apex:repeat value="{!notice.reasons}" var="r">
                            <li>{!r.text}</li>
                        </apex:repeat>
                    </ul>
                </apex:outputPanel>
                <apex:outputPanel rendered="{!notice.reasons.size == 0}" layout="none">
                    <p>The specific reasons for our decision are available on request.</p>
                </apex:outputPanel>
            </apex:outputPanel>

            <!-- FCRA credit score disclosure (15 U.S.C. 1681m), when a score was used -->
            <apex:outputPanel rendered="{!notice.creditScoreDisclosed}" layout="none">
                <div class="section-title">Credit report and score</div>
                <div class="score">{!notice.scoreDisclosure}</div>
            </apex:outputPanel>

            <!-- ECOA 701(a) anti-discrimination notice + oversight agency (1002.9(b)(1)) -->
            <div class="section-title">Your rights under the Equal Credit Opportunity Act</div>
            <div class="ecoa">{!notice.ecoaNotice}</div>

            <p>If you have questions about this notice, please contact us at the address above. If
               you wish to request the specific reasons for our decision in writing, you may do so
               within 60 days of receiving this notice.</p>

            <div class="footer">
                Veridact &mdash; every decision has a receipt. This notice is provided pursuant to
                the Equal Credit Opportunity Act (15 U.S.C. 1691 et seq.) and its implementing
                Regulation B (12 CFR 1002.9), and, where a consumer report was used, the Fair Credit
                Reporting Act (15 U.S.C. 1681m).
            </div>
        </apex:outputPanel>
    </apex:outputPanel>
</body>
</apex:page>
